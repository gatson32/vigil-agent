# ═══════════════════════════════════════════════════════════════
# VIGIL — Environment Configuration
# Copy this file to .env and fill in your keys
# ═══════════════════════════════════════════════════════════════

# Step 1: Basescan (free) — basescan.org/myapikey
BASESCAN_API_KEY=

# Step 2: Alchemy (Growth $49/mo recommended) — alchemy.com
ALCHEMY_API_KEY=

# Step 3: X/Twitter (Basic $100/mo) — developer.x.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Step 4: Telegram (free) — @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Step 5: Agent wallet private key (for ACP transactions)
VIGIL_PRIVATE_KEY=

# Step 6: GAME SDK (Virtuals integration)
GAME_API_KEY=
